# Claude API (https://console.anthropic.com 에서 발급)
CLAUDE_API_KEY=여기에_입력

# ── 텔레그램 Claude 비서 봇 ──────────────────────────────────────
# 1. @BotFather 에서 봇 생성 후 토큰 발급
TELEGRAM_BOT_TOKEN=여기에_입력
# 2. 본인 텔레그램 ID (https://t.me/userinfobot 에서 확인)
#    쉼표로 여러 명 허용 가능. 비워두면 전체 허용 (비권장)
TELEGRAM_ALLOWED_USER_IDS=여기에_입력

# ── Reddit 블로그 봇 ─────────────────────────────────────────────
# Reddit API (https://www.reddit.com/prefs/apps 에서 발급)
REDDIT_CLIENT_ID=여기에_입력
REDDIT_CLIENT_SECRET=여기에_입력
REDDIT_USER_AGENT=blog-bot/1.0

# WordPress
WP_URL=https://내블로그주소.com
WP_USERNAME=워드프레스_아이디
WP_APP_PASSWORD=워드프레스_앱_비밀번호
